{
  "openapi": "3.0.3",
  "info": {
    "title": "Web Hardware API Polyfill",
    "description": "Browser extension polyfill for Web USB, Web Serial, and Web Bluetooth APIs",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "USBDevice": {
        "type": "object",
        "description": "Web USB API Device interface",
        "required": ["vendorId", "productId", "deviceClass", "deviceSubclass", "deviceProtocol", "productName", "manufacturerName", "serialNumber"],
        "properties": {
          "vendorId": {
            "type": "integer"
          },
          "productId": {
            "type": "integer"
          },
          "deviceClass": {
            "type": "integer"
          },
          "deviceSubclass": {
            "type": "integer"
          },
          "deviceProtocol": {
            "type": "integer"
          },
          "productName": {
            "type": "string"
          },
          "manufacturerName": {
            "type": "string"
          },
          "serialNumber": {
            "type": "string"
          },
          "configuration": {
            "$ref": "#/components/schemas/USBConfiguration"
          },
          "configurations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/USBConfiguration"
            }
          }
        }
      },
      "USBConfiguration": {
        "type": "object",
        "required": ["configurationValue", "configurationName", "interfaces"],
        "properties": {
          "configurationValue": {
            "type": "integer"
          },
          "configurationName": {
            "type": "string"
          },
          "interfaces": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/USBInterface"
            }
          }
        }
      },
      "USBInterface": {
        "type": "object",
        "required": ["interfaceNumber", "alternates"],
        "properties": {
          "interfaceNumber": {
            "type": "integer"
          },
          "alternates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/USBAlternateInterface"
            }
          }
        }
      },
      "USBAlternateInterface": {
        "type": "object",
        "required": ["alternateSetting", "interfaceClass", "interfaceSubclass", "interfaceProtocol", "interfaceName", "endpoints"],
        "properties": {
          "alternateSetting": {
            "type": "integer"
          },
          "interfaceClass": {
            "type": "integer"
          },
          "interfaceSubclass": {
            "type": "integer"
          },
          "interfaceProtocol": {
            "type": "integer"
          },
          "interfaceName": {
            "type": "string"
          },
          "endpoints": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/USBEndpoint"
            }
          }
        }
      },
      "USBEndpoint": {
        "type": "object",
        "required": ["endpointNumber", "direction", "type", "packetSize"],
        "properties": {
          "endpointNumber": {
            "type": "integer"
          },
          "direction": {
            "type": "string",
            "enum": ["in", "out"]
          },
          "type": {
            "type": "string",
            "enum": ["bulk", "interrupt", "isochronous"]
          },
          "packetSize": {
            "type": "integer"
          }
        }
      },
      "SerialPort": {
        "type": "object",
        "description": "Web Serial API Port interface",
        "required": ["readable", "writable"],
        "properties": {
          "readable": {
            "type": "object",
            "description": "ReadableStream for incoming data"
          },
          "writable": {
            "type": "object",
            "description": "WritableStream for outgoing data"
          }
        }
      },
      "SerialOptions": {
        "type": "object",
        "properties": {
          "baudRate": {
            "type": "integer",
            "default": 9600
          },
          "dataBits": {
            "type": "integer",
            "enum": [7, 8],
            "default": 8
          },
          "stopBits": {
            "type": "integer",
            "enum": [1, 2],
            "default": 1
          },
          "parity": {
            "type": "string",
            "enum": ["none", "even", "odd"],
            "default": "none"
          },
          "bufferSize": {
            "type": "integer",
            "default": 255
          },
          "flowControl": {
            "type": "string",
            "enum": ["none", "hardware"],
            "default": "none"
          }
        }
      },
      "BluetoothDevice": {
        "type": "object",
        "description": "Web Bluetooth API Device interface",
        "required": ["id", "name", "gatt"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "gatt": {
            "$ref": "#/components/schemas/BluetoothRemoteGATTServer"
          }
        }
      },
      "BluetoothRemoteGATTServer": {
        "type": "object",
        "required": ["device", "connected"],
        "properties": {
          "device": {
            "$ref": "#/components/schemas/BluetoothDevice"
          },
          "connected": {
            "type": "boolean"
          }
        }
      },
      "BluetoothRemoteGATTService": {
        "type": "object",
        "required": ["device", "uuid"],
        "properties": {
          "device": {
            "$ref": "#/components/schemas/BluetoothDevice"
          },
          "uuid": {
            "type": "string"
          },
          "isPrimary": {
            "type": "boolean"
          }
        }
      },
      "BluetoothRemoteGATTCharacteristic": {
        "type": "object",
        "required": ["service", "uuid", "properties"],
        "properties": {
          "service": {
            "$ref": "#/components/schemas/BluetoothRemoteGATTService"
          },
          "uuid": {
            "type": "string"
          },
          "properties": {
            "type": "object",
            "properties": {
              "broadcast": {
                "type": "boolean"
              },
              "read": {
                "type": "boolean"
              },
              "writeWithoutResponse": {
                "type": "boolean"
              },
              "write": {
                "type": "boolean"
              },
              "notify": {
                "type": "boolean"
              },
              "indicate": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "RequestDeviceOptions": {
        "type": "object",
        "properties": {
          "filters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "vendorId": {
                  "type": "integer"
                },
                "productId": {
                  "type": "integer"
                },
                "classCode": {
                  "type": "integer"
                },
                "subclassCode": {
                  "type": "integer"
                },
                "protocolCode": {
                  "type": "integer"
                },
                "serialNumber": {
                  "type": "string"
                }
              }
            }
          },
          "exclusionFilters": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  }
}