{
  "manifest_version": 2,
  "name": "WebHW Hardware Bridge",
  "version": "1.0.0",
  "description": "Enables Web USB, Serial, and Bluetooth APIs in Firefox through native bridge",
  "permissions": [
    "nativeMessaging",
    "storage",
    "activeTab",
    "notifications",
    "<all_urls>"
  ],
  "optional_permissions": [
    "tabs",
    "webNavigation"
  ],
  "background": {
    "scripts": [
      "src/background/service_worker.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/polyfill_bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    "src/polyfills/*",
    "src/services/*",
    "src/models/*"
  ],
  "content_security_policy": "script-src 'self'; object-src 'none'; connect-src 'self';",
  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "WebHW Hardware Bridge",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "options_ui": {
    "page": "src/ui/device_center.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "applications": {
    "gecko": {
      "id": "webhw-bridge@webhw.dev",
      "strict_min_version": "58.0"
    }
  },
  "commands": {
    "toggle_bridge": {
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      },
      "description": "Toggle hardware bridge connection"
    }
  }
}